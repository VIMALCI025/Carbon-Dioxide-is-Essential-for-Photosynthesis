  pages:
  - pageName: Page 1
    pageText: From the given materials, select the materials which you would require
      to conduct this experiment.
    showDialogBox: 1
    showAlternatePanels: 1
    alternatePanels:
    - panel: {fileID: 1142061880}
      stayInUpcomingPages: 0
      enableOnce: 0
      hasBeenEnabledOnce: 0
  - pageName: Page 2
    pageText: Select the glassware and the solutions which you would require for
      this experiment.
    showDialogBox: 1
    showAlternatePanels: 1
    alternatePanels:
    - panel: {fileID: 1936092262}
      stayInUpcomingPages: 0
      enableOnce: 0
      hasBeenEnabledOnce: 0
  - pageName: Page 3
    pageText: Select the plant which has long and thin leaves to carry out the experiment.
    showDialogBox: 1
    showAlternatePanels: 1
    alternatePanels:
    - panel: {fileID: 1244550487}
      stayInUpcomingPages: 0
      enableOnce: 0
      hasBeenEnabledOnce: 0
  - pageName: Page 4
    pageText: Now let's keep the plant in the dark for around 48 hrs to destarch
      it.
    showDialogBox: 1
    showAlternatePanels: 1
    alternatePanels:
    - panel: {fileID: 1244550487}
      stayInUpcomingPages: 0
      enableOnce: 0
      hasBeenEnabledOnce: 0
  - pageName: Page 5
    pageText: Now let's keep the plant in the dark for around 48 hrs to destarch
      it.
    showDialogBox: 0
    showAlternatePanels: 1
    alternatePanels:
    - panel: {fileID: 476846386}
      stayInUpcomingPages: 0
      enableOnce: 0
      hasBeenEnabledOnce: 0
  - pageName: Page 6
    pageText: Why do we use a destarched plant to conduct this experiment? Click
