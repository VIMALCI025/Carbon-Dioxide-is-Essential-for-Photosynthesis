    showDialogBox: 1
    showAlternatePanels: 1
    alternatePanels:
    - panel: {fileID: 396460629}
      stayInUpcomingPages: 0
      enableOnce: 0
      hasBeenEnabledOnce: 0
    - panel: {fileID: 1244550487}
